{
  "version": 1,
  "targets": [
    {
      "label": "nextflow-monitor",
      "path": ".",
      "verifiers": {
        "compile": {
          "argv": ["go", "build", "./..."],
          "scope": "project",
          "input": "none"
        },
        "test": {
          "argv": ["go", "test", "./..."],
          "scope": "project",
          "input": "none"
        },
        "check": null,
        "lint": {
          "check": null,
          "fix": null
        }
      },
      "hooks": {
        "stubber_post": [],
        "implementer_post": [
          { "verifier": "compile" },
          { "verifier": "test" }
        ],
        "layer_post": [
          { "verifier": "compile" },
          { "verifier": "test" }
        ],
        "abstractor_post": [
          { "verifier": "compile" },
          { "verifier": "test" }
        ],
        "final_preverify": [
          { "verifier": "compile" },
          { "verifier": "test" }
        ]
      }
    }
  ]
}
