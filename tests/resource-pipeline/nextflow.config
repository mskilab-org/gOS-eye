manifest {
    name        = 'resource-test'
    description = 'Pipeline with real CPU/memory work for resource reporting verification'
    version     = '0.1.0'
}

process {
    executor = 'local'
}

trace {
    enabled = true
    fields = 'task_id,hash,name,status,exit,process,tag,submit,start,complete,duration,realtime,%cpu,rss,vmem,peak_rss,peak_vmem,cpus,memory,workdir'
}
